{
  "name": "bitebook",
  "private": true,
  "version": "0.1.0",
  "description": "BiteBook — the family recipe book. Lives at recipes.hxndev.com",
  "scripts": {
    "dev": "pnpm --filter @bitebook/web dev",
    "mobile": "pnpm --filter @bitebook/mobile start",
    "build": "pnpm --filter @bitebook/web build",
    "lint": "pnpm --filter @bitebook/web lint",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  }
}
